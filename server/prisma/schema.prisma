generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Feedback {
  id String @id @default(uuid())

  type       String
  comment    String
  date       String
  screenshot String?

  @@map("feedbacks")
}

model Message {
  id String @id @default(uuid())

  message String
  date    String

  @@map("message")
}
